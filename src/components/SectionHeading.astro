---
export interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: 'start' | 'center';
}
const { eyebrow, title, lede, align = 'start' } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---

<div class:list={['max-w-3xl', alignClass]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class:list={['mt-2 font-serif text-3xl text-sumi sm:text-4xl']}>{title}</h2>
  {lede && <p class="mt-4 text-lg text-ink-600">{lede}</p>}
</div>
