---
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};

const nav = [
  { href: '/tool', label: 'Pattern tool' },
  { href: '/guides', label: 'Guides' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-ink-200 bg-ivory/85 backdrop-blur supports-[backdrop-filter]:bg-ivory/70 sticky top-0 z-40">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-2 text-sumi" aria-label="Komon Lab home">
      <span class="font-serif text-xl tracking-tight">Komon Lab</span>
      <span class="hidden text-xs text-ink-400 sm:inline">— kimono patterns, sized for you</span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-1 sm:gap-2">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'rounded px-3 py-2 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'text-sumi underline underline-offset-4 decoration-2 decoration-indigo-500'
                  : 'text-ink-600 hover:text-sumi',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
