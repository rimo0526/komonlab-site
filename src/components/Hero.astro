---
export interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  /** Path inside /public, e.g. "/hero-landing.png". Optional — falls back to a CSS background. */
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow,
  title,
  lede,
  primaryCta,
  secondaryCta,
  image,
  imageAlt = '',
} = Astro.props;
---

<section class="relative overflow-hidden border-b border-ink-200 bg-ivory">
  <div class="container-wide grid items-center gap-12 py-16 lg:grid-cols-12 lg:gap-16 lg:py-24">
    <div class="lg:col-span-7">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="mt-3 text-4xl font-serif leading-tight text-sumi sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink-600">
        {lede}
      </p>
      {(primaryCta || secondaryCta) && (
        <div class="mt-8 flex flex-wrap gap-3">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary">
              {primaryCta.label}
              <span aria-hidden="true" class="ml-2">→</span>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary">{secondaryCta.label}</a>
          )}
        </div>
      )}
    </div>

    <div class="lg:col-span-5">
      <div class="relative aspect-[4/5] w-full overflow-hidden rounded-lg border border-ink-200 bg-ink-100 shadow-sm">
        {image ? (
          <img
            src={image}
            alt={imageAlt}
            width="640"
            height="800"
            loading="eager"
            decoding="async"
            class="h-full w-full object-cover"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center">
            <svg viewBox="0 0 200 250" class="h-2/3 w-2/3 text-indigo-700" aria-hidden="true">
              <!-- Stylised kimono silhouette -->
              <path
                d="M100 10 L80 30 L40 40 L60 70 L60 220 L100 240 L140 220 L140 70 L160 40 L120 30 Z"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linejoin="round"
              />
              <line x1="100" y1="30" x2="100" y2="240" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" />
              <path d="M60 90 L40 110 M140 90 L160 110" stroke="currentColor" stroke-width="2" fill="none" />
            </svg>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
