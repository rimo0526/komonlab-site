---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  /** Path component, e.g. "/tool". Used to build canonical + og:url. */
  path?: string;
  /** Open Graph image filename relative to /public. */
  ogImage?: string;
  /** ISO date for Article jsonld */
  datePublished?: string;
  dateModified?: string;
  /** Per-page structured data injected verbatim into <script type=application/ld+json>. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Breadcrumb trail: list of { name, path }. */
  breadcrumbs?: { name: string; path: string }[];
  /** Article tags for OG. */
  articleTags?: string[];
  noindex?: boolean;
}

const {
  title,
  description,
  path = '/',
  ogImage = '/og-default.png',
  datePublished,
  dateModified,
  jsonLd,
  breadcrumbs,
  articleTags,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://komonlab.com';
const canonical = new URL(path, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const fullTitle = path === '/' ? title : `${title} — Komon Lab`;

// Always-present site-wide structured data.
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Komon Lab',
  url: siteUrl,
  logo: new URL('/logo.png', siteUrl).toString(),
  description: 'Free, printable kimono patterns generated from your measurements.',
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Komon Lab',
  url: siteUrl,
  inLanguage: 'en',
};

const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: new URL(b.path, siteUrl).toString(),
      })),
    }
  : null;

// Compose final JSON-LD payload
const allLd: Record<string, unknown>[] = [organizationLd, websiteLd];
if (breadcrumbLd) allLd.push(breadcrumbLd);
if (jsonLd) {
  if (Array.isArray(jsonLd)) allLd.push(...jsonLd);
  else allLd.push(jsonLd);
}

const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiEnabled = Boolean(umamiId && umamiSrc);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex,follow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={datePublished ? 'article' : 'website'} />
    <meta property="og:site_name" content="Komon Lab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />
    {datePublished && <meta property="article:published_time" content={datePublished} />}
    {dateModified && <meta property="article:modified_time" content={dateModified} />}
    {articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Theme -->
    <meta name="theme-color" content="#faf7f0" />

    <!-- JSON-LD -->
    {allLd.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}

    <!-- Umami (cookieless, no PII). Only rendered when both env vars are set. -->
    {umamiEnabled && (
      <script async defer src={umamiSrc} data-website-id={umamiId} data-do-not-track="true"></script>
    )}
  </head>
  <body class="min-h-screen bg-ivory text-sumi antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-indigo-700 focus:px-3 focus:py-2 focus:text-ivory">
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
