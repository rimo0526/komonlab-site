# --- Umami analytics ---
# Cookieless, PII-free pageview tracking. Self-hosted or umami.is.
# These values are PUBLIC (compiled into the browser bundle); they are not secrets.
# If either is empty the analytics script is not rendered at all.
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# --- Optional: contact channel exposed on /about and /privacy ---
# Leave empty until a public-facing channel is decided.
PUBLIC_CONTACT_EMAIL=
PUBLIC_CONTACT_HANDLE=
